# ─────────────────────────────────────────────────────────────────────────────
# TorsionDesk — local environment template
#
# Copy to .env.local and fill in real values. NEVER commit .env.local (gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── Clerk (auth, organizations, custom roles, webhooks) ──────────────────────
# Source: Clerk Dashboard → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Source: Clerk Dashboard → Webhooks → (after creating the org endpoint) Signing Secret
# Used by verifyWebhook() to authenticate organization.created events (threat T-00-03).
CLERK_WEBHOOK_SIGNING_SECRET=

# Base URL of the deployed app — used for invitation email redirects (AUTH-02).
# Local dev: http://localhost:3000   Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=

# ── Supabase (Postgres + RLS + Storage) ─────────────────────────────────────
# Transaction pooler connection string (port 6543) — REQUIRED for serverless on
# Vercel. Drizzle client sets prepare:false for this pooler (RESEARCH Pitfall 3).
# Source: Supabase Dashboard → Project Settings → Database → Connection string (transaction pooler, :6543)
DATABASE_URL=

# Source: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Source: Supabase Dashboard → Project Settings → API → Publishable key
# IMPORTANT: Supabase migrated to new API keys. Use the key starting with
# `sb_publishable_...` here, NOT the legacy `anon` key. The publishable key
# is the browser-safe key used by Realtime Broadcast and Storage reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# !! SERVER-ONLY SECRET — bypasses Row Level Security (threat T-00-04). !!
# NEVER expose to the client. Do NOT prefix with NEXT_PUBLIC_. Used only for
# tenant provisioning and Supabase Storage uploads on the trusted server.
# Source: Supabase Dashboard → Project Settings → API → Secret key (starts with `sb_secret_...`)
SUPABASE_SERVICE_ROLE_KEY=

# ── Test project (cross-tenant RLS test, D-17) ───────────────────────────────
# A DEDICATED Supabase TEST project, NON-service-role connection string so the
# cross-tenant test exercises real RLS as the `authenticated` role.
# (Also documented in .env.test.example.)
TEST_DATABASE_URL=

# ── Square (on-site card payments in technician PWA) ───────────────────────────
# Square Web Payments SDK loads in the browser, so these two keys are safe to
# expose to the client. They identify your application and location only.
# Source: Square Developer Dashboard → Applications → (your app) → Credentials
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
# Source: Square Developer Dashboard → Locations → (location) → Location ID
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# !! SERVER-ONLY SECRET — used by the server to authorize Square card payments. !!
# NEVER expose to the client. Do NOT prefix with NEXT_PUBLIC_. The PWA sends
# the one-time card token to a dedicated audited server action; this token
# authorizes the charge server-side and writes the canonical ledger.
# Source: Square Developer Dashboard → Applications → (your app) → Credentials
SQUARE_ACCESS_TOKEN=

# ── Google Maps (address autocomplete in tech PWA new customer dialog) ───────
# Requires "Maps JavaScript API" + "Places API" enabled in Google Cloud Console.
# Source: Google Cloud Console → APIs & Services → Credentials → API Key
# Restrict key to: Maps JavaScript API + Places API, HTTP referrers only.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Upstash Redis (rate limiting — optional but recommended in production) ────
# Create a free Redis database at https://console.upstash.com
# Source: Upstash Console → Database → REST API → UPSTASH_REDIS_REST_URL / TOKEN
# If not set, rate limiting is disabled (safe for local dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Resend (customer/tech emails + open/delivery tracking) ────────────────────
# Source: Resend Dashboard → API Keys
RESEND_API_KEY=
# Source: Resend Dashboard → Webhooks → https://infantinosgaragedoor.com/api/webhooks/resend
RESEND_WEBHOOK_SECRET=

# ── Twilio (SMS reminders + on-the-way texts) ───────────────────────────────
# Source: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ── Vercel cron secret (protects /api/cron/* endpoints) ─────────────────────
# Generate a random 32+ char string; also add to Vercel env vars.
CRON_SECRET=
