# ─────────────────────────────────────────────────────────────────────────────
# TorsionDesk — local environment template
#
# Copy to .env.local and fill in real values. NEVER commit .env.local (gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── Clerk (auth, organizations, custom roles, webhooks) ──────────────────────
# Source: Clerk Dashboard → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Source: Clerk Dashboard → Webhooks → (after creating the org endpoint) Signing Secret
# Used by verifyWebhook() to authenticate organization.created events (threat T-00-03).
CLERK_WEBHOOK_SIGNING_SECRET=

# Base URL of the deployed app — used for invitation email redirects (AUTH-02).
# Local dev: http://localhost:3000   Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=

# ── Supabase (Postgres + RLS + Storage) ─────────────────────────────────────
# Transaction pooler connection string (port 6543) — REQUIRED for serverless on
# Vercel. Drizzle client sets prepare:false for this pooler (RESEARCH Pitfall 3).
# Source: Supabase Dashboard → Project Settings → Database → Connection string (transaction pooler, :6543)
DATABASE_URL=

# Source: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Source: Supabase Dashboard → Project Settings → API → Publishable key
# IMPORTANT: Supabase migrated to new API keys. Use the key starting with
# `sb_publishable_...` here, NOT the legacy `anon` key. The publishable key
# is the browser-safe key used by Realtime Broadcast and Storage reads.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# !! SERVER-ONLY SECRET — bypasses Row Level Security (threat T-00-04). !!
# NEVER expose to the client. Do NOT prefix with NEXT_PUBLIC_. Used only for
# tenant provisioning and Supabase Storage uploads on the trusted server.
# Source: Supabase Dashboard → Project Settings → API → Secret key (starts with `sb_secret_...`)
SUPABASE_SERVICE_ROLE_KEY=

# ── Test project (cross-tenant RLS test, D-17) ───────────────────────────────
# A DEDICATED Supabase TEST project, NON-service-role connection string so the
# cross-tenant test exercises real RLS as the `authenticated` role.
# (Also documented in .env.test.example.)
TEST_DATABASE_URL=
