# ============================================================================
# Test environment template — copy to .env.test and fill in real values.
# Used by the TENANT-01 cross-tenant RLS integration test (D-17).
# ============================================================================

# Connection string to the DEDICATED Supabase TEST project (never prod).
#
# CRITICAL: This MUST be a non-service-role connection string — i.e. it must
# connect as the `authenticated` Postgres role so Row Level Security policies
# are actually enforced. The service-role key BYPASSES RLS entirely, which
# would make the cross-tenant test pass falsely (it would read Tenant A's row
# from a Tenant B context because RLS never runs). See D-17 and RESEARCH
# Open Question #3 / threat T-00-01.
#
# Use the Supabase transaction pooler host (port 6543) so the postgres-js
# driver runs with prepare:false (PgBouncer transaction-mode safe).
TEST_DATABASE_URL=
